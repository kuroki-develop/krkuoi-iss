<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>TOEIC Game</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

<div id="game">
  <div id="status">
    <span id="score">Score: 0</span>
    <span id="lives">❤️❤️❤️❤️❤️</span>
    <span id="combo">Combo: 0</span>
    <span id="progress">0 / 20</span>
  </div>

  <h2 id="question">Ready?</h2>
  <div id="choices"></div>
</div>

<div id="result" style="display:none;">
  <h2>RESULT</h2>
  <p id="finalScore"></p>

  <input id="playerName" placeholder="名前" />
  <button id="saveBtn">保存</button>

  <ol id="ranking"></ol>

  <button onclick="location.reload()">もう一度</button>
</div>

<script src="script.js"></script>

</body>
</html>
